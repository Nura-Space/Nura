# Nura Environment Variables Example
# 环境变量示例 - 复制为 .env 并填写实际值
# Copy this file to .env and fill in your actual values

# ============================================================================
# Core LLM Configuration / 核心 LLM 配置
# ============================================================================
# These override settings in config/default.toml
# 这些变量会覆盖 config/default.toml 中的设置

NURA_LLM_API_KEY=your-api-key-here
NURA_LLM_MODEL=gpt-4
NURA_LLM_BASE_URL=https://api.openai.com/v1
NURA_LLM_MAX_TOKENS=4096
NURA_LLM_TEMPERATURE=1.0

# ============================================================================
# Context Management / 上下文管理
# ============================================================================
NURA_CONTEXT_MAX_TOKENS=128000
NURA_CONTEXT_KEEP_TURNS=10
NURA_CONTEXT_COMPRESS_THRESHOLD=0.5

# ============================================================================
# Memory Storage / 记忆存储
# ============================================================================
NURA_MEMORY_DIR=/path/to/your/memory

# ============================================================================
# Feishu Platform / 飞书平台
# ============================================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_PROFILE_PATH=profiles/assistant.yaml
FEISHU_ENABLE_VOICE_REPLY=false

# ============================================================================
# Volcengine TTS (for Feishu voice reply) / 火山引擎 TTS（用于飞书语音回复）
# ============================================================================
VOLCENGINE_TTS_TOKEN=your_volcengine_access_token
VOLCENGINE_TTS_APP_ID=your_volcengine_app_id

# ============================================================================
# Other Platforms (未来支持 / Future Support)
# ============================================================================
# DISCORD_BOT_TOKEN=your_discord_bot_token
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# SLACK_BOT_TOKEN=your_slack_bot_token
